# Development API base URL.
# Kosongkan (default) untuk menggunakan vite proxy (lihat vite.config.ts).
# Isi dengan URL backend yang hidup agar FE memanggil API langsung tanpa proxy:
# VITE_API_BASE_URL=https://backend-kamu.example.com

VITE_API_BASE_URL=

# Target untuk vite proxy (hanya dipakai saat VITE_API_BASE_URL kosong).
# Ganti dengan URL backend/ngrok yang sedang aktif, lalu restart `npm run dev`.
# Contoh:
# VITE_PROXY_TARGET=https://namamu.ngrok-free.app
# VITE_WS_TARGET=wss://namamu.ngrok-free.app
VITE_PROXY_TARGET=
VITE_WS_TARGET=
